#!/bin/bash
# Pre-warm SSH ControlMaster sessions before Ansible runs.
#
# Why: ansible's parallel forks can fire 5+ concurrent SSH connections,
# each triggering a TouchID prompt. With this wrapper, hosts are warmed
# sequentially up front (one calm TouchID prompt per host); ansible's
# subsequent forks multiplex through the warm masters with no further
# prompts.
#
# Approach: delegate host enumeration to ansible itself via
# `--list-hosts`. By definition the result matches the run that follows.

# Extract hostnames from `ansible[-playbook] --list-hosts` output.
# Both formats put hostnames as indented bare tokens; group / play /
# pattern headers always contain a colon or parentheses and so don't
# match this pattern.
__preauth_extract_hosts() {
  awk '/^[[:space:]]+[A-Za-z0-9._-]+$/ {gsub(/^[[:space:]]+/,""); print}'
}

# Warm one host: skip if its ControlMaster is already alive, else open
# a daemonized -fN session (triggers exactly one TouchID prompt).
__preauth_warm_host() {
  local h="$1"
  printf "  %-20s ... " "$h"
  if ssh -O check "$h" 2>/dev/null; then echo "✓ cached"; return; fi
  if ssh -fN -o ConnectTimeout=8 "$h" 2>/dev/null; then echo "✓"
  else echo "✗"; fi
}

# Skip preauth on ansible flags where it would be wasted or harmful:
#   -k / --ask-pass : password auth (typically a brand-new host without
#                     our SSH key — `ssh -fN` would just fail noisily)
#   query modes     : --list-hosts / --syntax-check / --list-tasks /
#                     --list-tags : ansible doesn't connect at all
__preauth_should_skip() {
  for a in "$@"; do
    case "$a" in
      -k|--ask-pass|--list-hosts|--syntax-check|--list-tasks|--list-tags)
        return 0 ;;
    esac
  done
  return 1
}

ansible_preauth() {
  local cmd="$1"; shift
  __preauth_should_skip "$@" && return 0
  local hosts
  hosts=$(command "$cmd" "$@" --list-hosts 2>/dev/null | __preauth_extract_hosts)
  [[ -z "$hosts" ]] && return 0
  echo "🔐 Pre-authenticating SSH sessions for Ansible..."
  while IFS= read -r h; do __preauth_warm_host "$h"; done <<< "$hosts"
}

ansible()          { ansible_preauth ansible          "$@"; command ansible          "$@"; }
ansible-playbook() { ansible_preauth ansible-playbook "$@"; command ansible-playbook "$@"; }
