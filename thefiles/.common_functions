#!/bin/bash

# Returns "macos" on Darwin, "unix" on Linux, "unknown" otherwise.
# "unix" exists for occasional Linux server use; non-macOS hosts get
# dotfiles symlinks but no automated package install (see env_bootstrap.sh).
detect_os() {
  case "$OSTYPE" in
    darwin*)    echo "macos" ;;
    linux-gnu*) echo "unix"  ;;
    *)          echo "unknown" ;;
  esac
}