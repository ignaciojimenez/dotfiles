#!/bin/bash

common(){
  # git aliases
  alias g=git
  alias ga='git add'
  alias gapa='git add --patch'
  alias gap='git apply'
  alias gdt='git diff-tree --no-commit-id --name-only -r'
  alias gau='git add --update'
  alias gstp='git stash pop'
  alias gcs='git commit -S'
  alias glg='git log --stat'

  # ls confs — prefer eza if available; fall back to plain ls.
  # Lean palette: file-type colors only, no icons, no per-file git
  # status indicators (those add a lot of visual noise on busy dirs).
  # Note: in eza, `-h` is `--header` (sizes are human-readable by
  # default). We omit it everywhere — the column-title row is noise
  # for an experienced terminal user.
  if command -v eza >/dev/null; then
    alias ls='eza -l --time-style=long-iso --group-directories-first'
    alias ll='eza -l --time-style=long-iso --group-directories-first'
    alias la='eza -la --time-style=long-iso --group-directories-first'
    alias lg='eza --group-directories-first'
    alias tree='eza --tree'
  else
    alias ls='ls -Flh --color=auto'
    export LSCOLORS='BxBxhxDxfxhxhxhxhxcxcx'
  fi

  # `cat` stays plain — no syntax-highlighting alias. Use `bat` explicitly
  # when you want it for code files; everyday cat / pipes / config dumps
  # are quieter without it.

  # Safety features
  set -o noclobber          # Prevent overwriting files with >
  alias rm='rm -i'          # Prompt before removal
  alias cp='cp -i'          # Prompt before overwrite
  alias mv='mv -i'          # Prompt before overwrite

  # Directory navigation
  alias d='dirs -v'
  alias 1='cd -1'
  alias 2='cd -2'
  alias 3='cd -3'

  # Directory stack
  alias pd='pushd'
  alias pod='popd'

  # Enable color support — load LS_COLORS for grep/completion menus,
  # but don't re-alias `ls`: the eza branch above already owns it,
  # and the plain-`ls` fallback sets its own color flag.
  if command -v dircolors >/dev/null; then
      eval "$(dircolors -b)"
      alias grep='grep --color=auto'
      alias fgrep='fgrep --color=auto'
      alias egrep='egrep --color=auto'
  fi

  # Reload the shell (i.e. invoke as a login shell). Single-quoted so
  # $SHELL is resolved at use-time rather than at alias-definition.
  alias reload='exec $SHELL -l'

  # ssh forcing password authentication
  alias sshp="ssh -o PreferredAuthentications=password -o PubkeyAuthentication=no"

  # Source Ansible SSH pre-authentication configuration
  if [[ -f ~/.ansible_preauth ]]; then
    source ~/.ansible_preauth
  fi
}

macos(){
  # Aliases below use single quotes so $HOME is resolved at use-time.

  # alias to launch brew_maintain
  if [ -f "$HOME/.scripts/brew_maintain" ]; then
    alias bmaintain='$HOME/.scripts/brew_maintain'
  else
    echo ".aliases: brew_maintain not found" >&2
  fi

  # alias to pi utilities
  if [ -f "$HOME/Documents/Workspaces/rpi-provisioner/provision_pi" ]; then
    alias provision_rpi='$HOME/Documents/Workspaces/rpi-provisioner/provision_pi'
  else
    echo ".aliases: provision_rpi not found" >&2
  fi

  # Function for python
  if [ -f "/usr/bin/python3" ]; then
    python() {
      if [[ -n "$VIRTUAL_ENV" ]]; then
        command python "$@"
        else
         /usr/bin/python3 "$@"
        fi
    }
  else
    echo ".aliases: python3 not found" >&2
  fi

  # Show/hide hidden files in Finder
  alias showh="defaults write com.apple.finder AppleShowAllFiles -bool true && killall Finder"
  alias hideh="defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder"

  # Send HTTP requests via lwp-request (libwww-perl). Define-time
  # expansion is intentional here — each iteration captures a different
  # $method into its own alias.
  # shellcheck disable=SC2139
  for method in GET HEAD POST PUT DELETE TRACE OPTIONS; do
    alias "${method}"="lwp-request -m '${method}'"
  done
}

unix(){
  # No Linux-specific aliases yet. The common() block above is
  # already cross-platform; modern-CLI replacements (eza/bat) are
  # gated on `command -v` so they activate automatically when
  # installed.
  :
}

# setting up common aliases
common

# setting up environment specific aliases
# reading and not executing to avoid command injection
case "$1" in
  "macos")
    macos
    ;;
  "unix")
    unix
    ;;
esac
